{
  "Oanda": {
    "ApiKey": "REPLACE_WITH_OANDA_API_KEY",
    "AccountId": "REPLACE_WITH_ACCOUNT_ID",
    "Environment": "fxpractice"
  },
  "Risk": {
    "DefaultRiskPercent": 1.0,
    "MaxPositionUnits": 1000000,
    "AtrStopMultiplier": 2.0,
    "AtrTargetMultiplier": 4.0,
    "MaxDailyDrawdownPercent": 3.0
  },
  "Filters": {
    "EnableAtrSpikeFilter": true,
    "AtrSpikeMultiplier": 2.0,
    "EnableNewsFilter": false,
    "NewsBufferMinutes": 30,
    "EnableSessionFilter": false,
    "SignalMaxAgeSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
