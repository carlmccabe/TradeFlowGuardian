//@version=6
// ============================================================
// TradeFlow Guardian — EURUSD v6 LIVE
// Indicator — webhook alerts only, not for backtesting
// Timeframe : M30
// SMA 8/22  |  EMA 191  |  RSI 14  |  ATR 14
// SL 2.4×   |  TP 5.5×  |  EMA dist 25–79 pips
// Session   : UTC 10–17 (blocks London open chop + NY open)
// Day filter : Friday blocked (28.6% WR, pre-weekend squaring)
// ============================================================
indicator("TFG — EURUSD v6 LIVE", overlay=true, max_labels_count=100)

// ── Inputs ────────────────────────────────────────────────────
i_smaPeriod1 = input.int(8,    "Fast SMA",             group="Strategy", minval=1)
i_smaPeriod2 = input.int(22,   "Slow SMA",             group="Strategy", minval=1)
i_emaPeriod  = input.int(191,  "Trend EMA",            group="Strategy", minval=1)
i_rsiPeriod  = input.int(14,   "RSI period",           group="Strategy", minval=1)
i_atrPeriod  = input.int(14,   "ATR period",           group="Strategy", minval=1)
i_slMult     = input.float(2.4, "SL ×ATR",             group="Strategy", minval=0.1, step=0.1)
i_tpMult     = input.float(5.5, "TP ×ATR",             group="Strategy", minval=0.1, step=0.1)
i_emaDistMin = input.float(25.0, "EMA dist min (pips)", group="Strategy", minval=0)
i_emaDistMax = input.float(79.0, "EMA dist max (pips)", group="Strategy", minval=0)

i_sessionOn   = input.bool(true,  "Session filter (10–17 UTC)", group="Session")
i_showBlocked = input.bool(true,  "Show blocked signals",       group="Session")
i_blockFri    = input.bool(true,  "Block Friday signals",       group="Session")

i_showLabels  = input.bool(true,  "Show signal labels",         group="Display")
i_showSLTP    = input.bool(true,  "Show SL/TP lines",           group="Display")
i_showTable   = input.bool(true,  "Show status table",          group="Display")

// ── Indicators ────────────────────────────────────────────────
pipSize = syminfo.currency == "JPY" ? 0.01 : 0.0001

sma1    = ta.sma(close, i_smaPeriod1)
sma2    = ta.sma(close, i_smaPeriod2)
ema     = ta.ema(close, i_emaPeriod)
rsi     = ta.rsi(close, i_rsiPeriod)
atr     = ta.atr(i_atrPeriod)
emaDist = math.abs(close - ema) / pipSize

// ── Session + day gate (UTC) ──────────────────────────────────
// dayofweek: 1=Sun 2=Mon 3=Tue 4=Wed 5=Thu 6=Fri 7=Sat
utcHour = hour(time, "UTC")
utcDay  = dayofweek(time, "UTC")

dayOk     = not i_blockFri or utcDay != 6
inSession = not i_sessionOn or
             ((utcHour >= 10 and utcHour < 17) and dayOk)

// ── Signal conditions ─────────────────────────────────────────
crossUp   = ta.crossover(sma1, sma2)
crossDown = ta.crossunder(sma1, sma2)
atrRising = atr > atr[1]
distOk    = emaDist >= i_emaDistMin and emaDist <= i_emaDistMax

longOk  = crossUp   and close > ema and rsi > 50 and atrRising and distOk and barstate.isconfirmed
shortOk = crossDown and close < ema and rsi < 50 and atrRising and distOk and barstate.isconfirmed

longFired  = longOk  and inSession
shortFired = shortOk and inSession

// ── SL / TP ──────────────────────────────────────────────────
longSL  = close - i_slMult * atr
longTP  = close + i_tpMult * atr
shortSL = close + i_slMult * atr
shortTP = close - i_tpMult * atr

// ── Plots ─────────────────────────────────────────────────────
plot(sma1, "Fast SMA",  color=color.new(color.blue,   0), linewidth=1)
plot(sma2, "Slow SMA",  color=color.new(color.orange,  0), linewidth=1)
plot(ema,  "Trend EMA", color=color.new(color.yellow,  0), linewidth=2)

bgcolor(close > ema ? color.new(color.green, 96) : color.new(color.red, 96))
bgcolor(inSession ? color.new(color.blue, 95) : na, title="Session")
plotshape(longFired,  "Long",  shape.triangleup,   location.belowbar, color.lime, size=size.small)
plotshape(shortFired, "Short", shape.triangledown,  location.abovebar, color.red,  size=size.small)

// ── SL/TP lines ───────────────────────────────────────────────
var line slLine = na
var line tpLine = na

if i_showSLTP and longFired
    line.delete(slLine)
    line.delete(tpLine)
    slLine := line.new(bar_index, longSL, bar_index + 40, longSL, color=color.red,  style=line.style_dashed, width=1)
    tpLine := line.new(bar_index, longTP, bar_index + 40, longTP, color=color.lime, style=line.style_dashed, width=1)

if i_showSLTP and shortFired
    line.delete(slLine)
    line.delete(tpLine)
    slLine := line.new(bar_index, shortSL, bar_index + 40, shortSL, color=color.red,  style=line.style_dashed, width=1)
    tpLine := line.new(bar_index, shortTP, bar_index + 40, shortTP, color=color.lime, style=line.style_dashed, width=1)

// ── Labels ───────────────────────────────────────────────────
if i_showLabels and longFired
    label.new(bar_index, low - atr,
              "▲ LONG\nEntry: " + str.tostring(close,  "#.00000") +
              "\nSL: "          + str.tostring(longSL,  "#.00000") +
              "\nTP: "          + str.tostring(longTP,  "#.00000") +
              "\nATR: "         + str.tostring(atr,     "#.00000") +
              "\nDist: "        + str.tostring(emaDist, "#.0") + " pips",
              style=label.style_label_up, color=color.lime, textcolor=color.black, size=size.small)

if i_showLabels and shortFired
    label.new(bar_index, high + atr,
              "▼ SHORT\nEntry: " + str.tostring(close,   "#.00000") +
              "\nSL: "           + str.tostring(shortSL,  "#.00000") +
              "\nTP: "           + str.tostring(shortTP,  "#.00000") +
              "\nATR: "          + str.tostring(atr,      "#.00000") +
              "\nDist: "         + str.tostring(emaDist,  "#.0") + " pips",
              style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)

if i_showBlocked and i_sessionOn and not inSession
    if longOk
        label.new(bar_index, low,  "▲ blocked", color=color.gray, textcolor=color.white,
                  style=label.style_label_up,   size=size.tiny)
    if shortOk
        label.new(bar_index, high, "▼ blocked", color=color.gray, textcolor=color.white,
                  style=label.style_label_down, size=size.tiny)

// ── Status table ──────────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 80), border_width=1)
if i_showTable and barstate.islast
    dayName    = utcDay == 2 ? "Mon" : utcDay == 3 ? "Tue" : utcDay == 4 ? "Wed" :
                 utcDay == 5 ? "Thu" : utcDay == 6 ? "Fri" : utcDay == 7 ? "Sat" : "Sun"
    dayBlocked = i_blockFri and utcDay == 6

    table.cell(tbl, 0, 0, "EURUSD v6 M30",    text_color=color.white,  text_size=size.normal)
    table.cell(tbl, 1, 0, "",                  text_color=color.white)
    table.cell(tbl, 0, 1, "Session",           text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 1, inSession ? "✓ ACTIVE" : "✗ BLOCKED",
               text_color=inSession ? color.lime : color.orange,         text_size=size.small)
    table.cell(tbl, 0, 2, "Day",               text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 2, dayName + (dayBlocked ? " ✗" : " ✓"),
               text_color=dayBlocked ? color.orange : color.lime,        text_size=size.small)
    table.cell(tbl, 0, 3, "Trend",             text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 3, close > ema ? "▲ BULL" : "▼ BEAR",
               text_color=close > ema ? color.lime : color.red,          text_size=size.small)
    table.cell(tbl, 0, 4, "RSI(" + str.tostring(i_rsiPeriod) + ")",
               text_color=color.gray,                                     text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(rsi, "#.#"),
               text_color=rsi > 50 ? color.lime : color.red,             text_size=size.small)
    table.cell(tbl, 0, 5, "EMA dist",          text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(emaDist, "#.#") + " pips",
               text_color=distOk ? color.lime : color.orange,            text_size=size.small)
    table.cell(tbl, 0, 6, "ATR rising",        text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 6, atrRising ? "✓" : "✗",
               text_color=atrRising ? color.lime : color.red,            text_size=size.small)
    table.cell(tbl, 0, 7, "ATR",               text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 7, str.tostring(atr, "#.00000"),
               text_color=color.white,                                    text_size=size.small)
    table.cell(tbl, 0, 8, "Signal",            text_color=color.gray,   text_size=size.small)
    table.cell(tbl, 1, 8, longFired ? "▲ LONG" : shortFired ? "▼ SHORT" : "—",
               text_color=longFired ? color.lime : shortFired ? color.red : color.gray,
               text_size=size.small)

// ── Webhook alerts ────────────────────────────────────────────
// TV alert: condition = "alert() function calls", message box blank.
if longFired
    alert(
        '{"instrument":"EUR_USD",'  +
        '"direction":"Long",'       +
        '"price":'      + str.tostring(close,  "0.00000") + ',' +
        '"atr":'        + str.tostring(atr,    "0.00000") + ',' +
        '"stopLoss":'   + str.tostring(longSL, "0.00000") + ',' +
        '"takeProfit":' + str.tostring(longTP, "#.00000") + '}',
        alert.freq_once_per_bar
    )

if shortFired
    alert(
        '{"instrument":"EUR_USD",'  +
        '"direction":"Short",'      +
        '"price":'      + str.tostring(close,   "0.00000") + ',' +
        '"atr":'        + str.tostring(atr,     "0.00000") + ',' +
        '"stopLoss":'   + str.tostring(shortSL, "0.00000") + ',' +
        '"takeProfit":' + str.tostring(shortTP, "0.00000") + '}',
        alert.freq_once_per_bar
    )
