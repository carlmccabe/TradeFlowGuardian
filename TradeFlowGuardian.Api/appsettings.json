{
  "Oanda": {
    "ApiKey": "REPLACE_WITH_OANDA_API_KEY",
    "AccountId": "REPLACE_WITH_ACCOUNT_ID",
    "Environment": "fxpractice"
  },
  "Risk": {
    "DefaultRiskPercent": 1.0,
    "MaxPositionUnits": 1000000,
    "AtrStopMultiplier": 2.0,
    "AtrTargetMultiplier": 4.0,
    "MaxDailyDrawdownPercent": 3.0
  },
  "Filters": {
    "EnableAtrSpikeFilter": true,
    "AtrSpikeMultiplier": 2.0,
    "EnableNewsFilter": false,
    "NewsBufferMinutes": 30,
    "EnableSessionFilter": false,
    "SignalMaxAgeSeconds": 60
  },
  "NewsFilter": {
    "Enabled": true,
    "BlockWindowMinutesBefore": 30,
    "BlockWindowMinutesAfter": 30,
    "MinimumImpactLevel": "High",
    "CacheRefreshHours": 6
  },
  "Webhook": {
    "Secret": "REPLACE_WITH_WEBHOOK_SECRET"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "StreamName": "tradeflow:signals",
    "ConsumerGroup": "workers",
    "ConsumerName": "worker-1"
  },
  "Dashboard": {
    "Origin": "http://localhost:5173"
  },
  "Postgres": {
    "ConnectionString": "Host=http://localhost:5432/;Database=tradeflow;Username=postgres;Password=postgres;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "StackExchange": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*"
}
