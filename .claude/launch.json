{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Redis",
      "runtimeExecutable": "redis-server",
      "runtimeArgs": [],
      "port": 6379
    },
    {
      "name": "API",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "TradeFlowGuardian.Api", "--launch-profile", "http"],
      "port": 5205
    },
    {
      "name": "Worker",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "TradeFlowGuardian.Worker"],
      "port": null
    },
    {
      "name": "Docker (core only)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "--profile", "core", "up", "--build"],
      "port": 8080
    },
    {
      "name": "Docker (full stack + monitoring)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "--profile", "core", "--profile", "monitoring", "up", "--build"],
      "port": 8080
    }
  ]
}
